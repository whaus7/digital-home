# Copy to .env.local and fill in your SMTP credentials

# For Gmail: use your full email and an App Password
# (Enable 2FA, then create App Password at https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where contact form submissions are sent (default: info@adigitalhome.com)
CONTACT_EMAIL=info@adigitalhome.com
